{
  "name": "testing-system-server",
  "version": "1.0.0",
  "description": "Backend API for Testing System",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:init": "node scripts/init-db.js",
    "seed:users": "node scripts/seed-users.js",
    "seed:templates": "node scripts/seed-templates.js",
    "seed:templates:force": "node scripts/seed-templates-force.js",
    "seed:all": "node scripts/seed-all.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "sequelize": "^6.35.2",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^7.1.5",
    "pdfkit": "^0.14.0",
    "puppeteer": "^23.5.0",
    "multer": "^1.4.5-lts.1",
    "moment": "^2.29.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "sequelize-cli": "^6.6.2"
  }
